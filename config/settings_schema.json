[
  {
    "name": "theme_info",
    "theme_name": "Odyssey Jewels",
    "theme_version": "0.1.0",
    "theme_author": "Odyssey Jewels",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "playfair_display_n4",
        "label": "Heading font"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "jost_n4",
        "label": "t:general.primary"
      },
      {
        "type": "range",
        "id": "type_heading_tracking",
        "min": -4,
        "max": 4,
        "step": 1,
        "unit": "px",
        "label": "Heading letter spacing",
        "default": 0
      },
      {
        "type": "range",
        "id": "type_eyebrow_tracking",
        "min": 0,
        "max": 8,
        "step": 1,
        "unit": "px",
        "label": "Eyebrow letter spacing",
        "default": 3
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "110rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 32
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FAF7F2",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#12263F",
        "label": "t:labels.foreground"
      },
      {
        "type": "header",
        "content": "Brand"
      },
      {
        "type": "color",
        "id": "color_navy",
        "default": "#0E1E33",
        "label": "Navy"
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#B76E79",
        "label": "Rose accent"
      },
      {
        "type": "color",
        "id": "color_accent_soft",
        "default": "#E7CFC9",
        "label": "Rose soft"
      },
      {
        "type": "color",
        "id": "color_contrast",
        "default": "#FAF7F2",
        "label": "On-dark text"
      },
      {
        "type": "header",
        "content": "Shape"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 0
      }
    ]
